# Конфигурация веб-хука уведомлений о нарушениях lint (bin/lint-markdown.cjs).
# Скопируйте в .env в корне проекта (.env в репозиторий не попадает).
#
# Приоритет: переменные окружения процесса важнее значений из .env.
# Без MDLINT_WEBHOOK_URL уведомления отключены; токен необязателен.
# URL обязан быть https:// (токен не уходит по нешифрованному каналу).

MDLINT_WEBHOOK_URL=https://example.com/hook
MDLINT_WEBHOOK_TOK=секретный-токен
