# Line endings: LF in repository and working tree (Node/markdown; safe on Windows clone)
* text=auto eol=lf

# Source and config
*.ts text eol=lf
*.js text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.md text diff=markdown eol=lf
*.mdc text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf
.npmrc text eol=lf
.nvmrc text eol=lf

# Binary (never normalize)
*.png binary
*.jpg binary
*.gif binary
*.webp binary
